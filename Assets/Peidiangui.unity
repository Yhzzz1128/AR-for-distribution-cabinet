    m_PersistentCalls:
      m_Calls: []
  m_text: "1. \u8FC7\u8F7D\u8DF3\u95F8\r\n- \u7ACB\u5373\u5173\u95ED\u9AD8\u529F\u7387\u7535\u5668\u3002\r
    -\u8BA1\u7B97\u603B\u8D1F\u8F7D\u529F\u7387\uFF0C\u786E\u4FDD\u4E0D\u8D85\u8FC7\u65AD\u8DEF\u5668\u989D\u5B9A\u503C\u768480%\u3002\r\n-
    \u5347\u7EA7\u65AD\u8DEF\u5668\u6216\u5206\u6D41\u7535\u8DEF\uFF08\u9700\u4E13\u4E1A\u7535\u5DE5\u64CD\u4F5C\uFF09\u3002\r\n2.
    \u77ED\u8DEF\u8DF3\u95F8\r\n-\u65AD\u5F00\u6240\u6709\u7535\u5668\uFF0C\u5C1D\u8BD5\u590D\u4F4D\u65AD\u8DEF\u5668\u3002\u82E5\u4ECD\u8DF3\u95F8\uFF0C\u68C0\u67E5\u7EBF\u8DEF\u7EDD\u7F18\u5C42\u662F\u5426\u7834\u635F\u3002\r\n-\u4F7F\u7528\u4E07\u7528\u8868\u6D4B\u91CF\u56DE\u8DEF\u7535\u963B\uFF0C\u6B63\u5E38\u503C\u5E94\uFF1E0.5M\u03A9\u3002\r\n3.
    \u6F0F\u7535\u8DF3\u95F8\r\n- \u6309\u4E0BRCD\u6D4B\u8BD5\u6309\u94AE\uFF0C\u786E\u8BA4\u4FDD\u62A4\u529F\u80FD\u6B63\u5E38\u3002\r\n-\u91CD\u70B9\u68C0\u67E5\u6F6E\u6E7F\u73AF\u5883\u7EBF\u8DEF\uFF0C\u5FC5\u8981\u65F6\u66F4\u6362\u9632\u6F6E\u63D2\u5EA7\u3002\r\n\u9884\u9632\u5EFA\u8BAE\uFF1A\r
    \u5B9A\u671F\u68C0\u67E5\u7EBF\u8DEF\u8001\u5316\u60C5\u51B5\uFF0C\u5BB6\u5EAD\u7535\u8DEF\u6BCF5\u5E74\u9700\u5168\u9762\u68C0\u6D4B\uFF08\u53C2\u8003\u300A\u4F4F\u5B85\u7535\u6C14\u8BBE\u8BA1\u89C4\u8303\u300BJGJ242\uFF09\u3002\r\n-
    \u907F\u514D\u63D2\u5EA7\u4E32\u8054\u4F7F\u7528\uFF0C\u5927\u529F\u7387\u7535\u5668\u5355\u72EC\u56DE\u8DEF\u4F9B\u7535\u3002"
